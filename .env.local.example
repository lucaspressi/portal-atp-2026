# ==========================================
# CLERK - Autenticação
# ==========================================
# 1. Crie conta em: https://clerk.dev
# 2. Crie uma aplicação
# 3. Copie as chaves abaixo
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# URLs de redirecionamento
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/portal

# ==========================================
# GOOGLE SHEETS API
# ==========================================
# 1. Acesse: https://console.cloud.google.com
# 2. Crie um projeto
# 3. Ative a API: Google Sheets API
# 4. Crie uma Service Account
# 5. Baixe a chave JSON
# 6. Compartilhe sua planilha com o email da service account

# Email da Service Account (ex: nome@projeto.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=seu-service-account@projeto.iam.gserviceaccount.com

# Private Key (cole aqui o conteúdo da chave, mantendo as \n)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ID da planilha (está na URL: https://docs.google.com/spreadsheets/d/ID_AQUI/edit)
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms

# ==========================================
# CONFIGURAÇÕES OPCIONAIS
# ==========================================
# Para modo de desenvolvimento sem Google Sheets (mock data)
USE_MOCK_DATA=false