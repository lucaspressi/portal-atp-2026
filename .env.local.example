# ==========================================
# CONFIGURAÇÃO OBRIGATÓRIA
# ==========================================
# ID da planilha Google Sheets
# Encontre na URL: https://docs.google.com/spreadsheets/d/{ID}/edit
GOOGLE_SHEET_ID=seu-id-da-planilha-aqui

# ==========================================
# CONFIGURAÇÃO OPCIONAL - CLERK (autenticação)
# ==========================================
# Para autenticação completa, configure em:
# https://clerk.dev
#
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_sua_chave_aqui
# CLERK_SECRET_KEY=sk_test_sua_chave_aqui
#
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/portal